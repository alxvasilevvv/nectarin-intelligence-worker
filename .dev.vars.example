# Local dev variables for `wrangler dev`.
# Copy this file to `.dev.vars` (which is gitignored) and edit.
#
# These override [vars] in wrangler.toml during local development only.
# For PRODUCTION secrets use `npx wrangler secret put <NAME>` instead — never
# commit real tokens or signing keys.

# OAuth 2.1 — leave blank (or set DEV_BYPASS=1) to disable auth locally.
# In production these identify this resource server to the authorization server.
OAUTH_ISSUER=""          # e.g. https://auth.unyly.com/   (trailing slash matters for JWKS URL)
OAUTH_AUDIENCE=""        # e.g. https://nectarin-intelligence.<subdomain>.workers.dev/mcp
OAUTH_JWKS_URL=""        # JWKS endpoint; if blank it is derived from OAUTH_ISSUER

# DEV_BYPASS=1 skips the bearer-token check entirely (local convenience).
# Set to 0 to exercise the real jose JWKS verifyToken() path with OAUTH_* set.
DEV_BYPASS="1"

# Rate limit (requests/min per token or IP). Default 60.
RATE_LIMIT_PER_MIN="60"

# ── Distribution / Unyly (single front door used by connect_via_unyly) ──
UNYLY_LISTING_URL="https://unyly.org/ru/mcp/nectarin-intelligence-worker"
UNYLY_PARTNER_ID="nectarin"
# UNYLY_ATTRIBUTION=1 appends a tracked "Сделано в NECTARIN · подключить через
# Unyly" footer to successful tool outputs (viral loop). Off unless set.
UNYLY_ATTRIBUTION="1"
# Marketplace base for federated external MCPs (mcp_federation connect links).
UNYLY_MARKETPLACE_URL="https://unyly.org/ru/mcp"
# ── Federation gateway (federation_invoke runtime proxy, fail-closed) ──
# Self-issued in Unyly dashboard (Gateway → POST /api/gateway-tokens).
# When UNYLY_GATEWAY_TOKEN is set, federation_invoke calls
#   https://gateway.unyly.org/mcp/<slug>
# with Bearer auth — one token for ALL federated servers, zero per-server URL config.
# Health check: GET https://gateway.unyly.org/mcp/ping
# In production: `npx wrangler secret put UNYLY_GATEWAY_TOKEN`
# UNYLY_GATEWAY_URL="https://gateway.unyly.org"
# UNYLY_GATEWAY_TOKEN="..."
# Per-server overrides (backward compatible — win over gateway default):
# FED_KEYWORD_DATA_URL="https://custom.example/mcp"
# FED_KEYWORD_DATA_TOKEN="..."

# Tenant metrics scaffold (v2.61): "mock" (default) | "kv"
# NECTARIN_TENANT_DATA_MODE="mock"

# ── Optional, for when callLLM() is wired to a real model (production: use
#    `wrangler secret put LLM_API_KEY` instead of putting it here) ──
# LLM_API_KEY=""
# LLM_MODEL="claude-3-7-sonnet"
